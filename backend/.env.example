# --- Uygulama ---
APP_ENV=development
# Frontend'in çağıracağı origin'ler (CORS), virgülle ayrılır
CORS_ORIGINS=http://localhost:3000

# --- LLM Katmanı (sağlayıcı-bağımsız) ---
# Aktif sağlayıcı: gemini | anthropic | (ileride) openai
LLM_PROVIDER=gemini
# Kullanılacak model (sağlayıcıya göre değişir)
LLM_MODEL=gemini-3.5-flash

# Sağlayıcı anahtarları — yalnızca kullandığını doldur
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# --- Supabase / pgvector (Sprint 1'de eklenecek) ---
SUPABASE_URL=
SUPABASE_KEY=
# Project Settings → Database → Connect → Connection string (URI)
CONNECTION_URL=
